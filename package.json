{
  "name": "corvusstar",
  "version": "1.0.0",
  "description": "c, c+, c++, c#, c*",
  "keywords": [
    "sprt",
    "gungnir",
    "calculus"
  ],
  "homepage": "https://github.com/Clinscott/CStar#readme",
  "bugs": {
    "url": "https://github.com/Clinscott/CStar/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Clinscott/CStar.git"
  },
  "license": "ISC",
  "author": "Craig Linscott",
  "type": "module",
  "bin": {
    "cstar": "./bin/cstar.js",
    "pennyone-mcp": "./bin/pennyone-mcp.js"
  },
  "main": "cstar.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "npm run test:node && npm run test:python",
    "test:python": "node scripts/run-python.mjs -m pytest tests/unit tests/integration tests/empire_tests tests/crucible",
    "test:node": "node scripts/run-tsx.mjs --test tests/*.test.ts tests/unit/*.test.ts tests/crucible/*.ts",
    "test:ipc": "node scripts/run-tsx.mjs --test tests/integration/ipc/*.test.ts",
    "test:empire": "node scripts/run-tsx.mjs --test tests/empire_tests/test_corvus_process_empire.ts tests/empire_tests/test_gateway_empire.ts",
    "setup": "node scripts/run-tsx.mjs src/node/setup.ts",
    "postinstall": "npm run setup",
    "install-os": "./scripts/install_cstar_os.sh",
    "uninstall-os": "./scripts/uninstall_cstar_os.sh"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.0.0",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.44.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sinclair/typebox": "^0.34.14",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "d3-force-3d": "^3.0.6",
    "dotenv": "^16.4.7",
    "execa": "^9.6.1",
    "express": "^4.22.1",
    "fast-glob": "^3.3.3",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.0.1",
    "gsap": "^3.14.2",
    "maath": "^0.10.8",
    "pino-pretty": "^13.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^27.0.2",
    "web-tree-sitter": "^0.26.6",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/express": "^4.17.25",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.150.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "eslint-plugin-jsdoc": "^62.7.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
