{
  "name": "corvus-star",
  "version": "1.0.0",
  "description": "Corvus Star (C*) host-native extension with Hall discovery, Augury routing, Council expert selection, and kernel-backed CStar control.",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "pennyone": {
      "command": "node",
      "args": ["${extensionPath}/../../bin/pennyone-mcp.js"],
      "env": {
        "CSTAR_ROOT": "${extensionPath}/../..",
        "NODE_ENV": "production"
      }
    },
    "corvus-control": {
      "command": "node",
      "args": ["${extensionPath}/../../scripts/run-tsx.mjs", "${extensionPath}/../../src/tools/corvus-control-mcp.ts"],
      "env": {
        "CSTAR_ROOT": "${extensionPath}/../..",
        "NODE_ENV": "production"
      }
    }
  },
  "settings": [
    {
      "name": "Persona",
      "envVar": "CSTAR_PERSONA",
      "default": "ALFRED",
      "description": "Active CStar persona (O.D.I.N. or ALFRED)"
    }
  ]
}
